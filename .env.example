EMAIL_TO=you@example.com
EMAIL_FROM=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your-google-app-password
DIGEST_TIMEZONE=America/Los_Angeles
CODEX_BIN=codex
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=medium
CODEX_ENABLE_SEARCH=true
CODEX_ENABLE_WILDCARD_DISCOVERY=true
CODEX_WILDCARD_CANDIDATES=8
TOP_N=15
CODEX_SHORTLIST_SIZE=25
ROBOTICS_SPOTLIGHT_COUNT=2
ROBOTICS_MIN_HEURISTIC_SCORE=2.5
