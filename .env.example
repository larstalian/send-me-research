# Used when you do not provide digest_profiles.json or DIGEST_PROFILES_JSON.
EMAIL_TO=you@example.com
EMAIL_FROM=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your-google-app-password
DIGEST_TIMEZONE=America/Los_Angeles
CODEX_BIN=codex
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=medium
CODEX_ENABLE_SEARCH=true
CODEX_ENABLE_WILDCARD_DISCOVERY=true
CODEX_WILDCARD_CANDIDATES=8
DEFAULT_PROFILE_NAME=default
DEFAULT_AUDIENCE_DESCRIPTION="ML related to LLMs, agents, robotics, and cyber/security, with extra emphasis on post-training, fine-tuning, self-improvement, tool use, code generation, code benchmarks, and methods that improve agentic task performance."
DEFAULT_PRIORITY_KEYWORDS="post-training,fine-tuning,self-distillation,tool use,code generation,benchmark,agentic tasks,prompt injection,robotics"
TOP_N=15
CODEX_SHORTLIST_SIZE=80
ARXIV_MAX_RESULTS=2000
ARXIV_CATEGORIES=cs.CL,cs.AI,cs.LG,cs.CR,cs.RO,cs.CV,cs.SE,cs.MA,cs.IR,cs.HC,stat.ML,eess.SY,eess.IV
ROBOTICS_SPOTLIGHT_COUNT=2
ROBOTICS_MIN_HEURISTIC_SCORE=2.5
STATE_RETENTION_DAYS=60
# Optional:
# CODEX_SECRET_SYNC_TOKEN=github_pat_with_actions_secrets_write
# OPENALEX_MAILTO=you@example.com
# DIGEST_PROFILES_PATH=/absolute/path/to/digest_profiles.json
