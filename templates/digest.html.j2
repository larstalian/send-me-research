<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Research Digest</title>
    <style>
      :root {
        --page: #f6f1e8;
        --paper: #fffdf9;
        --ink: #26211b;
        --muted: #736a61;
        --line: #ded5ca;
        --soft: #f1e9dd;
        --accent: #7b5c3f;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        padding: 28px 16px;
        background: var(--page);
        color: var(--ink);
        font-family: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
      }
      a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .shell {
        max-width: 860px;
        margin: 0 auto;
        background: var(--paper);
        border: 1px solid var(--line);
        box-shadow: 0 14px 36px rgba(63, 44, 23, 0.05);
      }
      .masthead {
        padding: 34px 40px 28px;
        border-bottom: 1px solid var(--line);
      }
      .kicker {
        margin: 0 0 10px;
        color: var(--muted);
        font-size: 11px;
        font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      h1 {
        margin: 0;
        font-size: 40px;
        line-height: 1.06;
        font-weight: 600;
        letter-spacing: -0.02em;
      }
      .subhead {
        margin: 14px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.6;
      }
      .summary {
        margin-top: 22px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
        font-size: 17px;
        line-height: 1.65;
      }
      .digest {
        padding: 8px 40px 28px;
      }
      .entry {
        padding: 28px 0 30px;
        border-bottom: 1px solid var(--line);
        page-break-inside: avoid;
      }
      .entry:last-child {
        border-bottom: none;
      }
      .eyebrow {
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 11px;
        font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }
      .title {
        margin: 0 0 10px;
        font-size: 29px;
        line-height: 1.18;
        font-weight: 600;
      }
      .authors {
        margin: 0 0 16px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
        font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      }
      .context {
        margin: 0 0 18px;
        padding: 12px 14px;
        border: 1px solid var(--line);
        background: #fbf7f0;
      }
      .context-head {
        margin: 0 0 6px;
        color: var(--muted);
        font-size: 11px;
        font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .context-copy {
        margin: 0;
        font-size: 14px;
        line-height: 1.7;
        color: var(--ink);
        font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      }
      .context-copy + .context-copy {
        margin-top: 6px;
        color: var(--muted);
      }
      .why {
        margin: 0 0 18px;
        padding: 14px 16px;
        background: var(--soft);
        border-left: 3px solid #cab396;
        font-size: 17px;
        line-height: 1.62;
      }
      .abstract {
        margin: 0;
        font-size: 17px;
        line-height: 1.82;
      }
      .links {
        margin-top: 16px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
        font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      }
      .links a {
        margin-right: 16px;
      }
      .action-link {
        display: inline-block;
        margin: 8px 12px 0 0;
        padding: 8px 12px;
        border: 1px solid var(--line);
        background: #faf5ed;
        color: var(--ink);
        text-decoration: none;
      }
      .action-link:hover {
        background: #f3ebdf;
      }
      .empty {
        padding: 32px 0 12px;
      }
      .empty h2 {
        margin: 0 0 10px;
        font-size: 28px;
        line-height: 1.2;
      }
      .empty p {
        margin: 0;
        font-size: 17px;
        line-height: 1.75;
      }
      .footer {
        padding: 0 40px 30px;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.7;
        font-family: "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      }
      @media screen and (max-width: 720px) {
        .masthead,
        .digest,
        .footer {
          padding-left: 22px;
          padding-right: 22px;
        }
        h1 {
          font-size: 33px;
        }
        .title {
          font-size: 25px;
        }
        .summary,
        .why,
        .abstract,
        .empty p {
          font-size: 16px;
        }
      }
      @media print {
        body {
          padding: 0;
          background: #ffffff;
        }
        .shell {
          border: none;
          box-shadow: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="masthead">
        <p class="kicker">Daily Research Digest</p>
        <h1>{{ digest_date }}</h1>
        <p class="subhead">{{ total }} curated papers · {{ window_label }}</p>
        <div class="summary">{{ summary }}</div>
      </header>

      <main class="digest">
        {% if entries %}
          {% for entry in entries %}
            <article class="entry">
              <p class="eyebrow">{{ entry.section }} · {{ entry.paper.source }} · Score {{ "%.1f"|format(entry.rank_score) }}</p>
              <h2 class="title">{{ entry.paper.title }}</h2>
              <p class="authors">{{ entry.paper.authors|join(", ") }}</p>
              {% if entry.provenance or entry.signal_rationale %}
                <div class="context">
                  <p class="context-head">Origin &amp; Signal · {{ "%.1f"|format(entry.signal_score) }}/10</p>
                  {% if entry.provenance %}
                    <p class="context-copy">{{ entry.provenance }}</p>
                  {% endif %}
                  {% if entry.signal_rationale %}
                    <p class="context-copy">{{ entry.signal_rationale }}</p>
                  {% endif %}
                </div>
              {% endif %}
              <p class="why">{{ entry.why_it_matters }}</p>
              <p class="abstract">{{ entry.paper.abstract or "Abstract unavailable." }}</p>
              <div class="links">
                <a href="{{ entry.paper.landing_url }}">Paper</a>
                {% if entry.paper.pdf_url %}
                  <a href="{{ entry.paper.pdf_url }}">PDF</a>
                {% endif %}
                {% if entry.paper.doi %}
                  <a href="{{ entry.paper.doi }}">DOI</a>
                {% endif %}
                <a
                  class="action-link ask-chatgpt"
                  href="{{ entry.chatgpt_url }}"
                  target="_blank"
                  rel="noopener noreferrer"
                >Ask ChatGPT</a>
              </div>
            </article>
          {% endfor %}
        {% else %}
          <section class="empty">
            <p class="eyebrow">No new papers</p>
            <h2>No strong additions today</h2>
            <p>The last 48-hour window did not surface any unseen papers strong enough for today’s digest.</p>
          </section>
        {% endif %}
      </main>

      <footer class="footer">
        Generated automatically with Codex-assisted curation, deterministic paper-source collection, and duplicate tracking.
      </footer>
    </div>
  </body>
</html>
